[Unit]
Description=Sync GitHub copilot-ready issues into secondorder
After=network-online.target

[Service]
Type=oneshot
ExecStart=%h/go/bin/gh-sync -db %h/.local/share/secondorder/so.db -repos castrojo/copilot-config,castrojo/cncf-darkmode,castrojo/documentation
StandardOutput=journal
StandardError=journal
